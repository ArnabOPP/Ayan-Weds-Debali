29w" src="./City5_files/T1dORVl8kMLXNd7ShMJWzCpoHtM.png" alt="" style="display:block;width:100%;height:100%;border-radius:inherit;corner-shape:inherit;object-position:center;object-fit:cover"></div></div></div></div><div class="framer-qt0921" data-framer-name="Meet the bride and groom" id="bride-and-groom"><div class="framer-11qrzzs" data-framer-name="Content"><div class="framer-14qyw1k" data-framer-name="Heading"><div class="ssr-variant hidden-111y3eh"><div class="framer-qzt986" data-framer-name="meet the" style="transform:none" data-framer-component-type="RichTextContainer"><p style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:30px;--framer-text-alignment:center;--framer-text-color:rgb(251, 237, 226)" class="framer-text">meet the</p></div></div><div class="ssr-variant hidden-111y3eh"><div class="framer-1wgh81x" data-framer-name="bride and groom" style="transform:none" data-framer-component-type="RichTextContainer"><p style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:70px;--framer-text-alignment:center;--framer-text-color:rgb(251, 237, 226)" class="framer-text"> bride and groom</p></div></div></div><div class="ssr-variant hidden-111y3eh"><div class="framer-1nr7fzo-container"><!--$--><div class="framer-UHnLD framer-s06v3h framer-v-s06v3h" data-framer-name="Variant 1" style="height: 100%; width: 100%; opacity: 1;"><div class="framer-vzvg8k" style="opacity: 1;"><div class="framer-ijl5j3" data-framer-name="We are both so delighted that you are able to join us in celebrating what we hope will be one of the happiest days of our lives. The affection shown to us by so many people since our roka has been incredibly moving, and has touched us both deeply. We would like to take this opportunity to thank everyone most sincerely for their kindness. We are looking forward to see you at the wedding." style="--extracted-r6o4lv: rgb(251, 237, 226); --framer-paragraph-spacing: 0px; transform: none; opacity: 1;" data-framer-component-type="RichTextContainer"><p style="--font-selector:R0Y7WWFsZGV2aS1yZWd1bGFy;--framer-font-family:&quot;Yaldevi&quot;, &quot;Yaldevi Placeholder&quot;, sans-serif;--framer-font-size:20px;--framer-line-height:1.3em;--framer-text-alignment:center;--framer-text-color:var(--extracted-r6o4lv, rgb(251, 237, 226))" class="framer-text">With the blessings of our elders and the love of our family and friends, we are delighted to invite you to celebrate one of the most joyous and auspicious occasions of our lives—our wedding.&nbsp;Your affection, good wishes, and constant support have meant so much to us and our families. As we begin this beautiful journey together, it would bring us immense happiness to have you with us, sharing in the joy and warmth of this special day.&nbsp;We sincerely hope you will grace the occasion with your presence and bless us as we step into this new chapter of life together.&nbsp;We look forward to celebrating this beautiful moment with you.
</p></div></div></div><!--/$--></div></div></div><div class="ssr-variant hidden-111y3eh"><div class="framer-rifffs-container"><!--$--><div class="framer-TbqMA framer-m9xna6 framer-v-m9xna6" data-framer-name="Desktop" style="width: 100%; opacity: 1;"><div class="framer-1b8vhu9" style="opacity: 1;"><div class="framer-4rlk9i" data-framer-name="The frame" style="opacity: 1;"><div style="position:absolute;border-radius:inherit;corner-shape:inherit;top:0;right:0;bottom:0;left:0" data-framer-background-image-wrapper="true"><img decoding="auto" width="506" height="758" sizes="(min-width: 1200px) 691.09px, (min-width: 810px) and (max-width: 1199.98px) 691.09px, (max-width: 809.98px) 389.87px" srcset="https://framerusercontent.com/images/54JwjUrKR8txnFhN4dFmme3FzoQ.png?width=506&amp;height=758 506w" src="./City5_files/54JwjUrKR8txnFhN4dFmme3FzoQ.png" alt="" style="display:block;width:100%;height:100%;border-radius:inherit;corner-shape:inherit;object-position:center;object-fit:cover"></div></div><div class="framer-1ozbtfd-container" style="opacity: 1;"><section style="display: flex; flex-direction: row; width: 100%; height: 100%; max-width: 100%; max-height: 100%; place-items: center; margin: 0px; padding: 0px; list-style-type: none; opacity: 1; user-select: none;"><div style="width:100%;height:100%;margin:0;padding:inherit;position:absolute;inset:0;overflow:hidden;border-radius:39px;user-select:none;perspective:1200px"><ul style="display: flex; flex-direction: row; width: 100%; height: 100%; max-width: 100%; max-height: 100%; place-items: center; margin: 0px; padding: 0px; list-style-type: none; gap: 0px; cursor: auto; user-select: none; transform: translateX(-2100px);"><li style="display:contents" aria-hidden="false"><div class="framer-679jd" data-framer-name="Wedding shoot 1" style="flex-shrink: 0; user-select: none; width: 100%; height: 100%; opacity: 1; visibility: visible; transform: none; transform-origin: 100% 50% 0px;" aria-hidden="true"><div style="position:absolute;